generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String?
  password  String   //  ADD THIS for pass
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

 model Product {
  id          Int     @id @default(autoincrement())
  name        String
  category    String
  price       Float
  unit        String
  location    String
  seller      String
  image       String

  description String
  stock       Int
  delivery    String
  quality     String
}

model Order {
  id          Int      @id @default(autoincrement())
  productId   Int
  productName String
  delivery    String
  image       String
  price       Float
  quantity    Int
  totalPrice  Float
  seller      String
  userEmail   String?
  createdAt   DateTime @default(now())
}